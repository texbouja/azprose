{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AZprose",
  "mainBinaryName": "azprose",
  "version": "0.1.0",
  "identifier": "com.azprose.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "AZprose",
        "width": 1240,
        "height": 820,
        "minWidth": 640,
        "minHeight": 420,
        "dragDropEnabled": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/azprose/azprose/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0OUEwNzYyQ0I5N0YxQ0EKUldUSzhaZkxZZ2VhTk41OVJRRk5idHV0OGZVQURMUVJpQ0t1eXJTMjF6YzhEcXpuVVlDL1NFSUEK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx"],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor",
        "rank": "Alternate"
      },
      {
        "ext": ["txt", "text", "csv", "tsv"],
        "name": "Text",
        "description": "Plain text file",
        "role": "Editor",
        "rank": "Alternate"
      },
      {
        "ext": ["html", "htm", "xhtml", "css", "js", "jsx", "ts", "tsx", "json", "xml", "yaml", "yml", "toml", "ini", "cfg", "conf", "env"],
        "name": "Code",
        "description": "Source code file",
        "role": "Editor",
        "rank": "Alternate"
      },
      {
        "ext": ["tex", "sty", "cls", "ltx", "bib"],
        "name": "LaTeX",
        "description": "LaTeX document",
        "role": "Editor",
        "rank": "Alternate"
      },
      {
        "ext": ["py", "rs", "rb", "go", "java", "c", "h", "cpp", "hpp", "swift", "kt", "sql", "sh", "r", "lua", "php", "pl", "pm", "dart"],
        "name": "Source Code",
        "description": "Source code file",
        "role": "Editor",
        "rank": "Alternate"
      },
      {
        "ext": ["png", "jpg", "jpeg", "gif", "bmp", "webp", "svg", "ico"],
        "name": "Image",
        "description": "Image file",
        "role": "Viewer",
        "rank": "Alternate"
      },
      {
        "ext": ["pdf"],
        "name": "PDF",
        "description": "PDF document",
        "role": "Viewer",
        "rank": "Alternate"
      }
    ]
  }
}
